PORT=5000
MONGO_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/chatapp

JWT_SECRET=replace_with_random_64char_string
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# AES-256-GCM message encryption key (min 32 chars, REQUIRED)
MESSAGE_SECRET=replace_with_random_64char_string

# Comma-separated list of allowed frontend origins
CLIENT_URL=https://your-frontend.vercel.app,http://localhost:5173

EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
